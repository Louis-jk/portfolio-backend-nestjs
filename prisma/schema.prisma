// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                  Int           @id @default(autoincrement())
  sortOrder           Int           @default(0)
  imageUrl            String                
  startDate           DateTime
  endDate             DateTime?
  isPublic            Boolean       @default(false)
  
  // 기술 스택, 플랫폼 카테고리, 도메인 태그 (영문/공통 텍스트 배열)
  technologies        String[]      @default([])    
  platformCategories  String[]      @default([])  
  domainTags          String[]      @default([])

  // 다국어 문자열 [ko, ja, en] (I18nStringDto 매핑)
  // 매핑 규격: {"ko": "...", "ja": "...", "en": "..."}
  title               Json
  company             Json
  role                Json
  overview            Json
  
  // 다국어 문자열 배열 [ko, ja, en] (I18nStringArrayDto 매핑)
  // 매핑 규격: {"ko": ["...", "..."], "ja": ["...", "..."], "en": ["...", "..."]}
  description         Json
  challenges          Json
  achievements        Json
  
  // 플랫폼 링크 구조 (PlatformsDto 매핑)
  // 매핑 규격: {"webLink": "...", "iosLink": "...", "androidLink": "...", "desktopLink": "..."}
  platforms           Json          @default("{}")
  
  // 도구 구조 (ToolsDto 매핑)
  // 매핑 규격: {"development": ["...", "..."], "communication": ["...", "..."], "design": ["...", "..."], "debugging": ["...", "..."]}
  tools               Json          @default("{}")

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model PortfolioDocument {
  id         BigInt                 @id @default(autoincrement())
  sourceType String                 @map("source_type")
  sourceId   Int                    @map("source_id")
  locale     String
  title      String
  content    String                 @db.Text
  metadata   Json                   @default("{}")
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @default(now()) @updatedAt @map("updated_at")

  @@unique([sourceType, sourceId, locale], map: "portfolio_documents_source_unique")
  @@index([sourceType, sourceId, locale], map: "portfolio_documents_source_idx")
  @@map("portfolio_documents")
}